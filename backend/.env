# --- CONFIGURACIÓN PARA PRODUCCIÓN (Hostinger / MySQL) ---
# Descomenta y completa con los datos de Hostinger:
# MYSQL_USER=u123456789_user
# MYSQL_PASSWORD=tu_password_seguro
# MYSQL_HOST=localhost (si el backend corre en hostinger) o ip_del_servidor
# MYSQL_PORT=3306
# MYSQL_DB=u123456789_polla_db

# O usa una URL completa (Recomendado para Render):
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname

